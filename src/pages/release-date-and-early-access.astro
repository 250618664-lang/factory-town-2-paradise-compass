---
import Base from '../layouts/Base.astro';
import NativeAdSlot from '../components/NativeAdSlot.astro';
const lastChecked = '2026-07-20';
---

<Base
  title="Release Date and Early Access Status"
  description="Factory Town 2: Paradise is now live on Steam Early Access — current status, launch date, and platform availability."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Release Date and Early Access Status' },
  ]}
>
  <div class="hero-grid">
    <div class="panel hero">
      <span class="eyebrow"><span class="dot"></span> Early Access Live</span>
      <h1>Release Date &amp;<br/>Early Access Status</h1>

      <!-- V2 Quick Answer — within first 100 words -->
      <div class="answer-strip">
        <div class="answer-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent-3)" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <div>
          <strong>Steam Early Access: July 14, 2026 — LIVE</strong>
          <span>Factory Town 2: Paradise launched into Steam Early Access on July 14, 2026. A demo is also available.</span>
        </div>
      </div>

      <NativeAdSlot />

      <!-- V2 ConfirmedFacts — primary structured module -->
      <div class="check-list" style="margin-top: 20px;">
        <div class="check-item done">
          <div class="check-num">✓</div>
          <div class="check-text">
            <strong>Steam Early Access — live since July 14, 2026</strong>
            <p>The game is available for purchase and play on Steam.</p>
          </div>
          <span class="check-badge good">Confirmed</span>
        </div>
        <div class="check-item done">
          <div class="check-num">✓</div>
          <div class="check-text">
            <strong>Steam Demo available</strong>
            <p>The official Steam demo is accessible from the game's Steam store page.</p>
          </div>
          <span class="check-badge good">Confirmed</span>
        </div>
        <div class="check-item hold">
          <div class="check-num">?</div>
          <div class="check-text">
            <strong>Price and editions</strong>
            <p>Current pricing and available editions are not recorded here — check the official Steam store page directly.</p>
          </div>
          <span class="check-badge warn">Verify first</span>
        </div>
        <div class="check-item hold">
          <div class="check-num">?</div>
          <div class="check-text">
            <strong>Platform requirements</strong>
            <p>PC system requirements have not been verified against official source on this page.</p>
          </div>
          <span class="check-badge warn">Verify first</span>
        </div>
      </div>

      <!-- V2 Player Decision Help -->
      <div class="partial-callout" style="margin-top: 16px; border-color: rgba(62,112,92,0.3); border-left-color: var(--good);">
        <strong style="color: var(--good);">Should I buy now or wait?</strong>
        <p>Factory Town 2 is in Steam Early Access. Check the official Steam description for the developer's progress roadmap before purchasing if you want to assess current feature completeness.</p>
      </div>
    </div>

    <aside class="panel side">
      <h2>Source</h2>
      <div class="source-card">
        <h3>Official Source</h3>
        <div class="source-row">
          <strong>Claim ID</strong>
          <span>ft2-release-live-20260720</span>
        </div>
        <div class="source-row">
          <strong>Fact</strong>
          <span>Steam Early Access: July 14, 2026 — LIVE</span>
        </div>
        <div class="source-row">
          <strong>Source</strong>
          <span>store.steampowered.com</span>
        </div>
        <div class="source-row">
          <strong>Last checked</strong>
          <span>{lastChecked}</span>
        </div>
        <div class="source-row">
          <strong>Status</strong>
          <span>Confirmed</span>
        </div>
      </div>

      <div class="mini" style="margin-top: 14px;">
        <h3>Action</h3>
        <p>Visit the official Steam page to confirm current price and system requirements before purchasing:</p>
        <p><a href="https://store.steampowered.com/app/3312130/Factory_Town_2_Paradise/" target="_blank" rel="noopener" style="color: var(--accent-3);">→ Steam Store Page</a></p>
      </div>

      <div class="mini" style="margin-top: 10px;">
        <h3>Related pages</h3>
        <p><a href="/demo-guide/">→ Demo Guide</a></p>
        <p><a href="/faq/">→ FAQ</a></p>
        <p><a href="/patch-notes/">→ Patch Notes</a></p>
      </div>
    </aside>
  </div>

  <!-- V2 FAQ section — 5 FAQs -->
  <section class="panel section">
    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 14px; display: grid; gap: 12px;">
      <div>
        <h3 style="font-size: 15px; margin-bottom: 4px;">Is Factory Town 2: Paradise already released?</h3>
        <p>Yes — it launched on Steam Early Access on <strong style="color: var(--good);">July 14, 2026</strong>. It is available for purchase and play now.</p>
      </div>
      <div>
        <h3 style="font-size: 15px; margin-bottom: 4px;">Is there a free demo?</h3>
        <p>Yes. A Steam demo is available. Check the official Steam store page to download it.</p>
      </div>
      <div>
        <h3 style="font-size: 15px; margin-bottom: 4px;">What does Early Access mean for this game?</h3>
        <p>Early Access on Steam means the game is available while still in active development. Refer to the developer's Steam description for their specific plans and timeline.</p>
      </div>
      <div>
        <h3 style="font-size: 15px; margin-bottom: 4px;">Where can I track official updates?</h3>
        <p>Official updates are posted on the <a href="https://steamcommunity.com/app/3312130/?curator_clanid=4777282" target="_blank" rel="noopener">Steam Community update hub</a>. This site's <a href="/patch-notes/">Patch Notes page</a> tracks concise verified summaries.</p>
      </div>
      <div>
        <h3 style="font-size: 15px; margin-bottom: 4px;">Are system requirements confirmed on this site?</h3>
        <p>No — PC system requirements have not been independently verified here. Check the official Steam store page for the latest official requirements before purchasing.</p>
      </div>
    </div>
  </section>

  <!-- V2 Related Guides -->
  <section class="panel section">
    <h2>Related Guides</h2>
    <div class="link-list" style="margin-top: 14px;">
      <a class="link-item" href="/demo-guide/">
        <div class="link-icon">▶️</div>
        <div>
          <strong>Demo Guide: What Is Confirmed</strong>
          <p>Demo availability and confirmed boundary.</p>
        </div>
        <span class="link-badge warn">Partial</span>
      </a>
      <a class="link-item" href="/patch-notes/">
        <div class="link-icon">📡</div>
        <div>
          <strong>Patch Notes and Official Updates</strong>
          <p>Verified update timeline linked to the official Steam update hub.</p>
        </div>
        <span class="link-badge good">Confirmed</span>
      </a>
      <a class="link-item" href="/faq/">
        <div class="link-icon">❓</div>
        <div>
          <strong>FAQ</strong>
          <p>Direct answers to launch and gameplay questions.</p>
        </div>
        <span class="link-badge good">Confirmed</span>
      </a>
    </div>
  </section>
</Base>
